  @Prop({
    default: null,
  })
  avatar?: string;

  @Prop({
    default: null,
  })
  bio?: string;

  @Prop({
    default: false,
  })
  isEmailVerified!: boolean;

  @Prop({
    default: true,
  })
  isActive!: boolean;

  @Prop({
    default: null,
